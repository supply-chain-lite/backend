SECRET_KEY=your-secret-key-here
# Pepper mixed into password hashes. Set once and never change it.
# For existing deployments: set this to the SECRET_KEY value that was used when passwords were first hashed.
PASSWORD_PEPPER=your-password-pepper-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
SQLITE_DB_PATH=./data.db
MAX_ATTEMPTS=5
LOCK_TIME_MINUTES=30
SMTP_URL="smtppro.zoho.in"
SMTP_PORT=465
SMTP_USER="support@summence.com"
SMTP_PWD="zzzzzzzz"
BASE_URL=http://localhost:3000
DATA_FOLDER="./data/"
LOG_LEVEL=INFO
BROKER_URL="redis://localhost:6379/0"
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_URL=
SETUP_S3=0
TASK_PROCESS_TIMEOUT_MINUTES=60